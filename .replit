modules = ["python-3.12", "nix", "nodejs-20"]
[nix]
channel = "stable-25_05"
packages = ["ffmpeg-full"]

[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Deploy to Cloudflare"

[[workflows.workflow]]
name = "Deploy to Cloudflare"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash deploy.sh"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80
